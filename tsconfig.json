{
    "compilerOptions": {
        // General
        "jsx": "preserve",
        "jsxImportSource": "solid-js",
        "target": "ESNext",

        // Modules
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "noEmit": true,
        "paths": {
            "@root/*": ["./src/*"],
            "lab-data": ["./data/lab-data.meta.ts"]
        },

        // Type resolution & Safety
        "strict": true,
        "types": ["vite/client"]
    }
}
