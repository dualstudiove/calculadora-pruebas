{
  "compilerOptions": {
    // General
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "target": "ES2022",
    "noEmit": true,

    // Modules
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowJs": true,
    "paths": {
      "@/*": [
        "./src/*",
        "./vite.config.ts"
      ]
    },

    // Type checking & safety
    "strict": true,
    "types": ["vite/client"]
  }
}
